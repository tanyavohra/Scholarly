FROM node:20-bookworm-slim

WORKDIR /app

# Native deps: bcrypt build tools; PDF thumbnailing: poppler utils
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ poppler-utils ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY server.js ./
COPY models ./models
COPY observability ./observability

ENV NODE_ENV=production
EXPOSE 10000
CMD ["npm","start"]
