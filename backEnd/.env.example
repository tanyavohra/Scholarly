## Node API
PORT=8081
NODE_ENV=development
JWT_SECRET=change-me
CORS_ORIGINS=https://scholarly-ruddy.vercel.app/

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=signup

PYTHON_BASE_URL=https://scholarly-k19m.onrender.com

# PDF processing (Node -> Python)
# Set this to your *Node* public domain so the Python service can download uploaded PDFs
# via `GET /processpdf/source/:token` (avoids multipart stream aborts on low-tier hosting).
# Example: PUBLIC_BASE_URL=https://your-node-service.onrender.com
PUBLIC_BASE_URL=
PROCESSPDF_SOURCE_URL_ENABLE=1
PROCESSPDF_SOURCE_TTL_MS=3600000
PROCESSPDF_SOURCE_MAX_ENTRIES=200
MAX_UPLOAD_BYTES=26214400
MAX_UPLOAD_FILES=1
PROCESSPDF_CONCURRENCY=1
PROCESSPDF_RATE_MAX=10
PROCESSPDF_RATE_WINDOW_MS=60000
MEM_TELEMETRY=1
MEM_TELEMETRY_INTERVAL_MS=30000
MEM_GUARD_MAX_RSS_BYTES=0
MEM_GUARD_MAX_HEAP_USED_BYTES=0
HEAP_SNAPSHOT_ENABLE=0
HEAP_SNAPSHOT_SIGNAL=SIGUSR2
HEAP_SNAPSHOT_DIR=
HTTP_TELEMETRY_SAMPLE_RATE=0.1

# Use async mode in production to avoid reverse-proxy timeouts.
PYTHON_PROCESS_PDF_ASYNC=1
PYTHON_PROCESS_PDF_TIMEOUT_MS=300000
PYTHON_PROCESS_PDF_RETRIES=1
PYTHON_PROCESS_PDF_RETRY_STATUS_CODES=502,503,504

## Python API (Flask)
# These can live in the same file if you run both services locally.
# If you deploy them separately, set env vars per-service instead.
PY_PORT=8082
FAISS_DIR=faiss_index

# PDF processing (Python)
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=300
MAX_UPLOAD_BYTES=26214400
PDF_DOWNLOAD_TIMEOUT_SECS=25
PROCESS_PDF_ASYNC=1
PROCESS_PDF_USE_SUBPROCESS=1
PROCESS_PDF_SUBPROCESS_START_METHOD=spawn
JOB_STALE_AFTER_SECS=1200
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MODEL_BATCH_SIZE=16
MAX_CHUNKS=
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
QA_MODEL_NAME=google/flan-t5-small
# QA_MODE is reserved for non-LLM modes: retrieval_only, context_only, no_llm
QA_MODE=
# QA_BACKEND controls where the LLM runs:
# - auto (default): use Hugging Face hosted inference if HUGGINGFACEHUB_API_TOKEN is set, else local transformers
# - hf_hub: always use Hugging Face hosted inference
# - local: always use local transformers pipeline (heavier)
QA_BACKEND=auto
QA_HF_TASK=text2text-generation
QA_TEMPERATURE=0.0
QA_MAX_LENGTH=256
QA_CONTEXT_MAX_CHARS=8000
GOOGLE_API_KEY=
HUGGINGFACEHUB_API_TOKEN=
MONGO_URI=
