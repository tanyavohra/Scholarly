## Node API
PORT=8081
NODE_ENV=development
JWT_SECRET=change-me
CORS_ORIGINS=https://scholarly-ruddy.vercel.app/

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=signup

PYTHON_BASE_URL=https://scholarly-k19m.onrender.com

# PDF processing (Node -> Python)
# URL-based PDF ingestion is disabled (uploads only).
MAX_UPLOAD_BYTES=26214400
MAX_UPLOAD_FILES=1
PROCESSPDF_CONCURRENCY=1
PROCESSPDF_RATE_MAX=10
PROCESSPDF_RATE_WINDOW_MS=60000
MEM_TELEMETRY=1
MEM_TELEMETRY_INTERVAL_MS=30000
MEM_GUARD_MAX_RSS_BYTES=0
MEM_GUARD_MAX_HEAP_USED_BYTES=0
HEAP_SNAPSHOT_ENABLE=0
HEAP_SNAPSHOT_SIGNAL=SIGUSR2
HEAP_SNAPSHOT_DIR=
HTTP_TELEMETRY_SAMPLE_RATE=0.1

# Use async mode in production to avoid reverse-proxy timeouts.
PYTHON_PROCESS_PDF_ASYNC=1
PYTHON_PROCESS_PDF_TIMEOUT_MS=300000
PYTHON_PROCESS_PDF_RETRIES=1
PYTHON_PROCESS_PDF_RETRY_STATUS_CODES=502,503,504

## Python API (Flask)
# These can live in the same file if you run both services locally.
# If you deploy them separately, set env vars per-service instead.
PY_PORT=8082

# PDF processing (Python)
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=300
MAX_UPLOAD_BYTES=26214400
PDF_DOWNLOAD_TIMEOUT_SECS=60
PROCESS_PDF_ASYNC=1
PROCESS_PDF_USE_SUBPROCESS=1
PROCESS_PDF_SUBPROCESS_START_METHOD=spawn
JOB_STALE_AFTER_SECS=1200
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNKS=1000
MAX_QUERY_CHUNKS=1200
RETRIEVER_TOP_K=6
QA_MODEL_NAME=katanemo/Arch-Router-1.5B:hf-inference
QA_BACKEND=hf_chat
# Optional: override HF router base URL (normally leave as default)
HF_ROUTER_BASE_URL=https://router.huggingface.co/v1
QA_MAX_NEW_TOKENS=256
QA_TEMPERATURE=0.0
QA_CONTEXT_MAX_CHARS=8000
QA_TIMEOUT_S=90
QA_MAX_WORDS=140
QA_REPETITION_PENALTY=1.15
QA_TOP_P=0.9
QA_DO_SAMPLE=0
# Allow limited general knowledge (definitions/synonyms) while still requiring PDF-backed claims
# to be supported by the retrieved context.
QA_ALLOW_GENERAL_KNOWLEDGE=0
# Optional retrieval query synonym expansion for abbreviations. Format:
#   "ai=artificial intelligence;ml=machine learning"
QA_QUERY_SYNONYMS=
# Expand abbreviations/acronyms for retrieval by scanning document text (helps queries like "ai" match
# text like "artificial intelligence" even if the PDF never defines "AI").
QA_ABBREV_EXPAND=0
QA_ACRONYM_EXPAND=1
QA_ABBREV_SCAN_MAX_CHARS=200000
QA_INCLUDE_CONTEXT=0
QA_CONTEXT_AS_RESPONSE=0
QA_HF_METHOD=
QA_EXTRACTIVE_MAX_ANSWER_WORDS=40
QA_VERBOSE_WARNINGS=0
HF_TOKEN=
HUGGINGFACEHUB_API_TOKEN=
PDF_MONGO_DB=test
PDF_GRIDFS_BUCKET=pdf_fs
MONGO_URI=
