    { "source": "/question", "destination": "https://scholarlynode.onrender.com/question" },
    { "source": "/question_marked", "destination": "https://scholarlynode.onrender.com/question_marked" },
    { "source": "/question_tags", "destination": "https://scholarlynode.onrender.com/question_tags" },
    { "source": "/question_unmarked", "destination": "https://scholarlynode.onrender.com/question_unmarked" },
