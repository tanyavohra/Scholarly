## Frontend (refined UI - Vite)
# Used to point the UI at the API in non-proxied deployments.
# In production, set this to your API public URL (no trailing slash).
VITE_API_BASE_URL=http://localhost:8081

## Docker Compose (backend services)
MONGO_URI=mongodb://localhost:27017/brainlink
JWT_SECRET=dev-insecure-change-me
CORS_ORIGINS=http://localhost:3000

## AI provider keys (optional; required if your pdf Q&A uses them)
GOOGLE_API_KEY=
HUGGINGFACEHUB_API_TOKEN=
